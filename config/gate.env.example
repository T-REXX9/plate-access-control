# Keep this at 0 until all switches and 3.3 V-compatible signal inputs are wired.
GATE_MODE=0
GATE_GPIO_CHIP=/dev/gpiochip0

# BCM GPIO numbering (not physical header-pin numbering).
GATE_LOOP_GPIO=17
GATE_PASSAGE_GPIO=27
GATE_TRAFFIC_GPIO=22
GATE_OPEN_GPIO=23
GATE_CLOSE_GPIO=24

# Inputs use internal pull-ups: switch open = inactive, short to GND = active.
# One movement output is pulsed HIGH at a time. Traffic LOW=red, HIGH=green.
GATE_INPUT_DEBOUNCE_MS=300
GATE_RELAY_PULSE_MS=1000
GATE_RECOGNITION_TIMEOUT_MS=20000
GATE_OPENING_TRAVEL_MS=3000
GATE_PASSAGE_TIMEOUT_MS=30000
GATE_CLEARANCE_MS=1500
GATE_CLOSING_TRAVEL_MS=3000
