# Physical movement is intentionally disabled until the barrier terminal
# voltages, contact behavior, and relay polarity have been verified.
GATE_HARDWARE_ENABLED=0
GATE_GPIO_CHIP=/dev/gpiochip0

# Proposed BCM GPIO line numbers. These remain configurable.
GATE_LOOP_GPIO=17
GATE_PASSAGE_GPIO=27
GATE_OPEN_LIMIT_GPIO=22
GATE_CLOSED_LIMIT_GPIO=23
GATE_FAULT_GPIO=24
GATE_OPEN_RELAY_GPIO=5
GATE_CLOSE_RELAY_GPIO=6
GATE_RED_LIGHT_GPIO=13
GATE_GREEN_LIGHT_GPIO=19

# Set polarity only after testing the actual isolated modules.
GATE_INPUTS_ACTIVE_LOW=0
GATE_RELAYS_ACTIVE_LOW=1
GATE_LIGHT_RELAYS_ACTIVE_LOW=1

GATE_INPUT_DEBOUNCE_MS=300
GATE_RELAY_PULSE_MS=500
GATE_RECOGNITION_TIMEOUT_MS=20000
GATE_OPENING_TIMEOUT_MS=12000
GATE_PASSAGE_TIMEOUT_MS=30000
GATE_CLEARANCE_MS=1500
GATE_CLOSING_TIMEOUT_MS=12000
