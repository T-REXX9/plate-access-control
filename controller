#!/usr/bin/env bash
set -euo pipefail

project_dir="/opt/plate-controller"
config_path="/etc/plate-controller/controller.env"
service_name="plate-controller.service"

become_root() {
    if [[ $EUID -ne 0 ]]; then
        exec sudo "$0" "$@"
    fi
}

usage() {
    cat <<'EOF'
Plate controller management

  controller -status      Show whether the controller is running
  controller -logs        Follow live detection and gate logs
  controller -update      Safely pull, build, test, and restart
  controller -configure   Find/configure the PC server and camera
  controller -check       Check the configured PC server connection
  controller -start       Start the controller
  controller -stop        Stop the controller
  controller -restart     Restart the controller
  controller -help        Show this help
EOF
}

command_name="${1:--help}"
case "$command_name" in
    -status|status)
        systemctl --no-pager --full status "$service_name" || true
        ;;
    -logs|logs)
        become_root "$@"
        journalctl -u "$service_name" -f -n 100
        ;;
    -check|check)
        become_root "$@"
        PLATE_READER_CONFIG="$config_path" "$project_dir/start_reader.sh" --check
        ;;
    -start|start)
        become_root "$@"
        if [[ ! -f "$config_path" ]]; then
            echo "The PC server and camera are not configured yet." >&2
            echo "Run: controller -configure" >&2
            exit 1
        fi
        systemctl enable --now "$service_name"
        systemctl --no-pager --full status "$service_name" || true
        ;;
    -stop|stop)
        become_root "$@"
        systemctl stop "$service_name"
        echo "Plate controller stopped."
        ;;
    -restart|restart)
        become_root "$@"
        systemctl restart "$service_name"
        systemctl --no-pager --full status "$service_name" || true
        ;;
    -configure|configure)
        become_root "$@"
        systemctl stop "$service_name" 2>/dev/null || true
        PLATE_READER_CONFIG="$config_path" "$project_dir/configure_reader.sh"
        chown root:platecontroller "$config_path"
        chmod 640 "$config_path"
        systemctl enable --now "$service_name"
        echo "Configuration complete. The plate controller is running."
        ;;
    -update|update)
        become_root "$@"
        old_revision="$(git -C "$project_dir" rev-parse HEAD)"
        echo "Stopping the plate controller..."
        systemctl stop "$service_name" 2>/dev/null || true
        echo "Downloading the latest main-branch update..."
        if git -C "$project_dir" fetch origin main &&
           git -C "$project_dir" merge --ff-only origin/main &&
           bash "$project_dir/install_controller.sh" --refresh; then
            if [[ -f "$config_path" ]]; then
                echo "Update complete. The plate controller is running."
            else
                echo "Update complete. Run controller -configure after the PC server is ready."
            fi
        else
            echo "The update failed. Restoring the previous working version..." >&2
            git -C "$project_dir" reset --hard "$old_revision"
            bash "$project_dir/install_controller.sh" --refresh
            echo "The previous version was restored and restarted." >&2
            exit 1
        fi
        ;;
    -help|help|--help)
        usage
        ;;
    *)
        echo "Unknown command: $command_name" >&2
        usage >&2
        exit 2
        ;;
esac
